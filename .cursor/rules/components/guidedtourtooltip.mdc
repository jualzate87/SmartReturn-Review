/** GuidedTourTooltip component */
const GuidedTourTooltip = (props: GuidedTourTooltipProps) => {
  const [index, setIndex] = React.useState(0);
  const activeElement = React.useRef<HTMLUnknownElement | null | undefined>(
    null
  );

  /** check if function is a promise */
  const isPromise = (method: any) =>
    !!method && typeof method.then === 'function';

  /** close the tour */
  const closeTour = () => {
    const { onClose } = props.steps[index];
    const closeIndex = 0;
    setIndex(closeIndex);

    const { onClose: onCloseTour } = props;
    onCloseTour && onCloseTour();
    // Set focus on active element
    if (activeElement && activeElement.current && activeElement.current.focus) {
      activeElement.current.focus();
    }

    onClose && onClose(closeIndex);
  };

  /** resolve any promises */
  const resolveCallbackList = (
    callbackList: CallbackType[],
    callbackIndex = 0
  ) => {
    const currCallback = callbackList[callbackIndex];
    if (callbackIndex >= callbackList.length) {
      return;
    }

    const callbackResult =
      currCallback.callback && currCallback.callback(currCallback.index);
    if (isPromise(callbackResult)) {
      callbackResult
        .then(() => {
          resolveCallbackList(callbackList, callbackIndex + 1);
        })
        .catch((error: React.ErrorInfo) => {
          console.warn(error);
          closeTour();
        });
    } else {
      resolveCallbackList(callbackList, callbackIndex + 1);
    }
  };

  /** function to transition the tooltip */
  const transitionTooltip = (
    currIndex: number,
    newIndex: number,
    callback: CallBackPayload
  ) => {
    const callbackList: CallbackType[] = [];
    const { onPreUnload } = props.steps[currIndex];
    const { onPreload } = props.steps[newIndex];
    if (onPreUnload) {
      callbackList.push({
        callback: onPreUnload,
        index: currIndex
      });
    }

    if (onPreload) {
      callbackList.push({
        callback: onPreload,
        index: newIndex
      });
    }

    callbackList.push({ callback });
    resolveCallbackList(callbackList);
  };

  /** handle back button click */
  const handleBackButtonClick = () => {
    const prevIndex = index - 1;
    const { onBackClick } = props.steps[index];
    transitionTooltip(index, prevIndex, () => {
      setIndex(prevIndex);
      if (typeof onBackClick === 'function') {
        onBackClick(prevIndex);
      }
    });
  };

  /** handle next button click */
  const handleNextButtonClick = () => {
    const nextIndex = index + 1;
    const { onNextClick } = props.steps[index];
    transitionTooltip(index, nextIndex, () => {
      setIndex(nextIndex);
      if (typeof onNextClick === 'function') {
        onNextClick(nextIndex);
      }
    });
  };

  /**  setup the callbacks to close the tour */
  const handleClose = () => {
    const callbackList: CallbackType[] = [];
    if (props.steps[index].onPreUnload) {
      callbackList.push({
        callback: props.steps[index].onPreUnload,
        index
      });
    }

    callbackList.push({
      callback: () => {
        closeTour();
      }
    });
    resolveCallbackList(callbackList);
  };

  /** function to render the tooltips */
  const getTooltips = (stepCount: number): React.ReactNodeArray => {
    const { autoFocus, open, steps, ofLabel, doneLabel, automationId } = props;

    return steps.map((step, stepIndex) => {
      const targetElement = Array.isArray(step.targetElement)
        ? step.targetElement[0]
        : step.targetElement;
      activeElement.current = Array.isArray(step.activeElement)
        ? step.activeElement[0]
        : step.activeElement;

      // Warnt the users if they are using deprecated props under steps
      if (step.offsetX) {
        console.warn(
          'offsetX prop is deprecated. Please use tooltipOffsetSkidding prop instead'
        );
      }

      if (step.offsetY) {
        console.warn(
          'offsetY prop is deprecated. Please use tooltipOffsetDistance prop instead'
        );
      }

      const guidanceTooltip = (
        <GuidanceTooltip
          // eslint-disable-next-line react/no-array-index-key
          key={stepIndex}
          dismissible
          usedForGuidedTour
          autoFocus={autoFocus}
          theme={props.theme}
          index={stepIndex}
          alignment={step.alignment}
          targetElement={targetElement}
          activeElement={activeElement.current}
          open={open && index === stepIndex}
          preventOverflow={step.preventOverflow}
          offsetX={step.offsetX || 0}
          tooltipOffsetSkidding={step.tooltipOffsetSkidding || 0}
          enableClickAway={step.enableClickAway}
          offsetY={step.offsetY || 0}
          tooltipOffsetDistance={step.tooltipOffsetDistance || 0}
          animationOn={stepIndex === 0}
          message={
            <>
              {step.message}
              {stepCount > 1 && (
                <Footer
                  index={index}
                  count={stepCount}
                  ofLabel={ofLabel}
                  theme={props.theme}
                  backLabel={step.backLabel || 'Back'}
                  doneLabel={doneLabel}
                  nextLabel={step.nextLabel || 'Next'}
                  onBackButtonClick={handleBackButtonClick}
                  onNextButtonClick={handleNextButtonClick}
                  onDoneButtonClick={handleClose}
                />
              )}
            </>
          }
          automationId={automationId && `${automationId}_${stepIndex + 1}`}
          title={step.title || 'Title'}
          stylePosition={step.stylePosition ? step.stylePosition(step) : null}
          position={step.position}
          className={clsx(step.className, styles.guidanceTourTooltipWrapper)}
          colorScheme={props.colorScheme}
          onClose={handleClose}
        >
          {step.targetElement ? null : <div />}
        </GuidanceTooltip>
      );

      if (step.renderCoachMarks) {
        return open && index === stepIndex
          ? step.renderCoachMarks({
              children: guidanceTooltip,
              key: stepIndex,
              open: guidanceTooltip.props.open,
              targetElement,
              alignment: step.alignment,
              position: step.position,
              onClose: handleClose
            })
          : null;
      }

      return guidanceTooltip;
    });
  };

  /** render guidance tooltip */
  const renderGuidanceTooltip = (stepCount: number) => {
    const tooltips = getTooltips(stepCount);

    if (props.renderGuidanceTooltip) {
      return props.renderGuidanceTooltip(tooltips, handleClose, props);
    }

    return tooltips;
  };

  const { steps, open } = props;

  const stepCount = steps.length;
  if (stepCount > 6 || stepCount < 3) {
    console.warn('Ideally 3-4 and no more than 6 steps are recommended');
  }

  return open ? <>{renderGuidanceTooltip(stepCount)} </> : null;
};

GuidedTourTooltip.defaultProps = {
  autoFocus: true,
  steps: [{}],
  ofLabel: 'of',
  doneLabel: 'Done'
};

export default GuidedTourTooltip;


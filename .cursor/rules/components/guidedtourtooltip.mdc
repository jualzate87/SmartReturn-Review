() => {
  return (
    <div>
      <GTTMixin>
        {(props: GTTMixinProps) => {
          const style = {
            display: 'inline-block',
            width: '400px',
            height: '400px',
            border: '1px solid black'
          };
          const letters = ['A', 'B', 'C', 'D', 'E', 'F'];
          const refs = [
            props.inputARef,
            props.inputBRef,
            props.inputCRef,
            props.inputDRef,
            props.inputERef,
            props.inputFRef
          ];
          return (
            <>
              <Button onClick={props.onButtonClick}>Click Me</Button>
              <div style={{ width: '100vw' }}>
                <div ref={props.assignARef} style={style}>
                  This is Block 1
                </div>
                <div ref={props.assignBRef} style={style}>
                  This is Block 2
                </div>
                <div ref={props.assignCRef} style={style}>
                  This is Block 3
                </div>
                <div ref={props.assignDRef} style={style}>
                  This is Block 4
                </div>
                <div ref={props.assignERef} style={style}>
                  This is Block 5
                </div>
                <div ref={props.assignFRef} style={style}>
                  This is Block 6
                </div>
              </div>
              <GuidedTourTooltip
                open={props.showToolTip}
                steps={letters.map((letter, index) => ({
                  title: `Title ${letter}`,
                  targetElement: refs[index],
                  activeElement: props.buttonRef.current,
                  message:
                    'Passing renderCoachMarks prop adds an overlay and focus area support',
                  position: 'top',
                  alignment: 'right',
                  onClose: props.onClose,
                  enableClickAway: false,
                  renderCoachMarks: (GTTprops: GuidedTourTooltipProps) => (
                    <CoachMarks {...GTTprops} targetDomNode={refs[index]}>
                      {GTTprops.children}
                    </CoachMarks>
                  )
                }))}
                onClose={props.onClose}
              />
            </>
          );
        }}
      </GTTMixin>
    </div>
  );
}
